{
  "name": "openpipestress-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "dev:desktop": "npm run dev --workspace apps/desktop",
    "build:desktop": "npm run build --workspace apps/desktop",
    "test:desktop": "npm test --workspace apps/desktop",
    "generate:product-preview-mechanics": "cargo run --quiet --manifest-path core/product_physics/Cargo.toml --example preview_result > fixtures/product_preview/invented_mechanics_result.json"
  }
}

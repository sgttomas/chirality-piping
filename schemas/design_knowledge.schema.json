{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpipestress.org/schemas/design_knowledge.schema.json",
  "title": "OpenPipeStress Design Knowledge Schema",
  "description": "Strict JSON Schema 2020-12 contract for user-supplied design knowledge records, provenance, source notes, and unresolved assumptions. The schema defines public structure only and does not bundle owner standards, protected standards data, proprietary project data, or code-specific acceptance criteria.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "deliverable_id",
    "package_id",
    "scope_item",
    "objectives",
    "data_boundary",
    "design_knowledge"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "deliverable_id": {
      "const": "DEL-13-01"
    },
    "package_id": {
      "const": "PKG-13"
    },
    "scope_item": {
      "const": "SOW-067"
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "contains": {
        "const": "OBJ-014"
      },
      "items": {
        "type": "string",
        "enum": [
          "OBJ-014"
        ]
      }
    },
    "data_boundary": {
      "$ref": "#/$defs/DataBoundary"
    },
    "design_knowledge": {
      "$ref": "#/$defs/DesignKnowledgeEnvelope"
    }
  },
  "$defs": {
    "AssumptionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assumption_id",
        "statement",
        "status",
        "affected_refs",
        "provenance"
      ],
      "properties": {
        "assumption_id": {
          "$ref": "#/$defs/Id"
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "unresolved",
            "resolved",
            "rejected",
            "TBD"
          ]
        },
        "affected_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "resolution_note": {
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "Coordinate3": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "z"
      ],
      "properties": {
        "x": {
          "$ref": "#/$defs/Quantity"
        },
        "y": {
          "$ref": "#/$defs/Quantity"
        },
        "z": {
          "$ref": "#/$defs/Quantity"
        },
        "coordinate_system_ref": {
          "$ref": "#/$defs/Reference"
        }
      }
    },
    "DataBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_examples_policy",
        "protected_source_policy",
        "private_data_policy",
        "unit_policy",
        "professional_boundary"
      ],
      "properties": {
        "public_examples_policy": {
          "const": "invented_or_cleared_data_only"
        },
        "protected_source_policy": {
          "const": "no_bundled_protected_owner_or_standards_data"
        },
        "private_data_policy": {
          "const": "user_controlled_private_paths"
        },
        "unit_policy": {
          "const": "unit_bearing_values_require_explicit_unit_metadata"
        },
        "professional_boundary": {
          "$ref": "#/$defs/ProfessionalBoundary"
        }
      }
    },
    "DesignKnowledgeEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "knowledge_set_id",
        "project_ref",
        "model_ref",
        "records",
        "diagnostics",
        "provenance"
      ],
      "properties": {
        "knowledge_set_id": {
          "$ref": "#/$defs/Id"
        },
        "project_ref": {
          "$ref": "#/$defs/Reference"
        },
        "model_ref": {
          "$ref": "#/$defs/Reference"
        },
        "records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/EndpointRecord"
              },
              {
                "$ref": "#/$defs/LineDataRecord"
              },
              {
                "$ref": "#/$defs/RoutingCorridorRecord"
              },
              {
                "$ref": "#/$defs/ZoneRecord"
              },
              {
                "$ref": "#/$defs/EquipmentInterfaceRecord"
              },
              {
                "$ref": "#/$defs/RequirementRecord"
              },
              {
                "$ref": "#/$defs/MetadataRecord"
              }
            ]
          }
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Diagnostic"
          }
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "Diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "class",
        "severity",
        "source",
        "affected_object",
        "message",
        "remediation",
        "provenance"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "class": {
          "type": "string",
          "enum": [
            "PROVENANCE_WARNING",
            "ASSUMPTION_WARNING",
            "IP_BOUNDARY_WARNING",
            "UNIT_WARNING",
            "MISSING_DATA",
            "SCHEMA_VALIDATION",
            "TBD"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "blocking"
          ]
        },
        "source": {
          "$ref": "#/$defs/Reference"
        },
        "affected_object": {
          "$ref": "#/$defs/Reference"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "remediation": {
          "type": "string",
          "minLength": 1
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "EndpointRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "record_kind",
        "name",
        "endpoint_role",
        "location",
        "connection_refs",
        "source_notes",
        "assumptions",
        "provenance"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "record_kind": {
          "const": "endpoint"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "endpoint_role": {
          "type": "string",
          "enum": [
            "start",
            "end",
            "tie_in",
            "equipment_interface",
            "boundary_condition",
            "TBD"
          ]
        },
        "location": {
          "$ref": "#/$defs/Coordinate3"
        },
        "connection_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "source_notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourceNote"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AssumptionRecord"
          }
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "EquipmentInterfaceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "record_kind",
        "name",
        "equipment_ref",
        "interface_role",
        "location",
        "interface_parameters",
        "source_notes",
        "assumptions",
        "provenance"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "record_kind": {
          "const": "equipment_interface"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "equipment_ref": {
          "$ref": "#/$defs/Reference"
        },
        "interface_role": {
          "type": "string",
          "enum": [
            "nozzle",
            "terminal_point",
            "equipment_boundary",
            "vendor_connection",
            "TBD"
          ]
        },
        "location": {
          "$ref": "#/$defs/Coordinate3"
        },
        "interface_parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "source_notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourceNote"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AssumptionRecord"
          }
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "GeometryPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "geometry_kind",
        "coordinate_refs",
        "boundary_refs",
        "quantities"
      ],
      "properties": {
        "geometry_kind": {
          "type": "string",
          "enum": [
            "point",
            "polyline",
            "volume",
            "surface",
            "abstract_reference",
            "TBD"
          ]
        },
        "coordinate_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "boundary_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "quantities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Quantity"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "Id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$"
    },
    "LineDataRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "record_kind",
        "name",
        "line_identifier",
        "service",
        "attributes",
        "source_notes",
        "assumptions",
        "provenance"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "record_kind": {
          "const": "line_data"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "line_identifier": {
          "type": "string",
          "minLength": 1
        },
        "service": {
          "type": "string",
          "minLength": 1
        },
        "attributes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "source_notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourceNote"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AssumptionRecord"
          }
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "MetadataRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "record_kind",
        "name",
        "metadata_scope",
        "metadata_values",
        "source_notes",
        "assumptions",
        "provenance"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "record_kind": {
          "const": "owner_project_metadata"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "metadata_scope": {
          "type": "string",
          "enum": [
            "project",
            "area",
            "line",
            "equipment",
            "document_reference",
            "TBD"
          ]
        },
        "metadata_values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "source_notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourceNote"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AssumptionRecord"
          }
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "Parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameter_id",
        "name",
        "value",
        "value_kind",
        "provenance"
      ],
      "properties": {
        "parameter_id": {
          "$ref": "#/$defs/Id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/Quantity"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "value_kind": {
          "type": "string",
          "enum": [
            "text",
            "quantity",
            "reference_list",
            "TBD"
          ]
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "PrivacyClassification": {
      "type": "string",
      "enum": [
        "public_metadata",
        "invented_public_example",
        "private_project_data",
        "owner_project_metadata_private",
        "protected_suspected",
        "redacted",
        "TBD"
      ]
    },
    "ProfessionalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_review_required",
        "software_makes_compliance_claim",
        "software_makes_certification_claim",
        "software_makes_sealing_claim",
        "software_makes_approval_claim",
        "software_makes_authentication_claim"
      ],
      "properties": {
        "human_review_required": {
          "const": true
        },
        "software_makes_compliance_claim": {
          "const": false
        },
        "software_makes_certification_claim": {
          "const": false
        },
        "software_makes_sealing_claim": {
          "const": false
        },
        "software_makes_approval_claim": {
          "const": false
        },
        "software_makes_authentication_claim": {
          "const": false
        }
      }
    },
    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_name",
        "source_location",
        "source_license",
        "contributor",
        "contributor_certification",
        "redistribution_status",
        "review_status",
        "privacy_classification"
      ],
      "properties": {
        "source_name": {
          "type": "string",
          "minLength": 1
        },
        "source_location": {
          "type": "string",
          "minLength": 1
        },
        "source_license": {
          "type": "string",
          "minLength": 1
        },
        "contributor": {
          "type": "string",
          "minLength": 1
        },
        "contributor_certification": {
          "type": "string",
          "minLength": 1
        },
        "redistribution_status": {
          "$ref": "#/$defs/RedistributionStatus"
        },
        "review_status": {
          "$ref": "#/$defs/ReviewStatus"
        },
        "privacy_classification": {
          "$ref": "#/$defs/PrivacyClassification"
        }
      }
    },
    "Quantity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "unit",
        "dimension",
        "provenance"
      ],
      "properties": {
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "dimension": {
          "type": "string",
          "enum": [
            "dimensionless",
            "length",
            "angle",
            "slope",
            "area",
            "volume",
            "temperature",
            "pressure",
            "force",
            "TBD"
          ]
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "RedistributionStatus": {
      "type": "string",
      "enum": [
        "public_permissive",
        "private_only",
        "unknown",
        "protected_suspected",
        "invented_non_engineering_example",
        "TBD"
      ]
    },
    "Reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_type",
        "ref"
      ],
      "properties": {
        "object_type": {
          "type": "string",
          "enum": [
            "Project",
            "Model",
            "Node",
            "Element",
            "Component",
            "Support",
            "EquipmentInterface",
            "DesignKnowledge",
            "Constraint",
            "Assumption",
            "SourceDocument",
            "Zone",
            "Corridor",
            "Metadata",
            "TBD"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        }
      }
    },
    "RequirementRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "record_kind",
        "name",
        "requirement_type",
        "target_refs",
        "requirement_statement",
        "parameters",
        "source_notes",
        "assumptions",
        "provenance"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "record_kind": {
          "const": "requirement"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "requirement_type": {
          "type": "string",
          "enum": [
            "access",
            "slope",
            "drain",
            "vent",
            "clearance",
            "support",
            "owner_project_metadata",
            "TBD"
          ]
        },
        "target_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "requirement_statement": {
          "type": "string",
          "minLength": 1
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "source_notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourceNote"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AssumptionRecord"
          }
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "ReviewStatus": {
      "type": "string",
      "enum": [
        "pending",
        "accepted",
        "rejected",
        "quarantined",
        "TBD"
      ]
    },
    "RoutingCorridorRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "record_kind",
        "name",
        "corridor_role",
        "geometry",
        "source_notes",
        "assumptions",
        "provenance"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "record_kind": {
          "const": "routing_corridor"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "corridor_role": {
          "type": "string",
          "enum": [
            "preferred_route",
            "allowed_route",
            "reserved_space",
            "avoidance_buffer",
            "TBD"
          ]
        },
        "geometry": {
          "$ref": "#/$defs/GeometryPayload"
        },
        "source_notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourceNote"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AssumptionRecord"
          }
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "SourceNote": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "note_id",
        "note_type",
        "statement",
        "source_ref",
        "visibility",
        "provenance"
      ],
      "properties": {
        "note_id": {
          "$ref": "#/$defs/Id"
        },
        "note_type": {
          "type": "string",
          "enum": [
            "source_note",
            "design_basis_note",
            "assumption_note",
            "private_note",
            "TBD"
          ]
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "$ref": "#/$defs/Reference"
        },
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "private",
            "redacted",
            "TBD"
          ]
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "ZoneRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "record_kind",
        "name",
        "zone_type",
        "geometry",
        "source_notes",
        "assumptions",
        "provenance"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "record_kind": {
          "const": "zone"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "zone_type": {
          "type": "string",
          "enum": [
            "no_go_volume",
            "supportable_zone",
            "access_zone",
            "maintenance_zone",
            "operating_zone",
            "TBD"
          ]
        },
        "geometry": {
          "$ref": "#/$defs/GeometryPayload"
        },
        "source_notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourceNote"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AssumptionRecord"
          }
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    }
  }
}

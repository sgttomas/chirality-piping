{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpipestress.org/schemas/constraint.schema.json",
  "title": "OpenPipeStress Constraint Entity Schema",
  "description": "Strict JSON Schema 2020-12 contract for provenance-marked constraint records. The schema defines structure for user, project, import, agent, and source-derived constraints without bundling protected standards data, owner requirements, proprietary project values, or engineering acceptance logic.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "deliverable_id",
    "package_id",
    "scope_items",
    "objectives",
    "data_boundary",
    "constraint_set"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "deliverable_id": {
      "const": "DEL-13-02"
    },
    "package_id": {
      "const": "PKG-13"
    },
    "scope_items": {
      "type": "array",
      "minItems": 2,
      "contains": {
        "enum": [
          "SOW-067",
          "SOW-068"
        ]
      },
      "items": {
        "type": "string",
        "enum": [
          "SOW-067",
          "SOW-068"
        ]
      }
    },
    "objectives": {
      "type": "array",
      "minItems": 2,
      "contains": {
        "enum": [
          "OBJ-014",
          "OBJ-018"
        ]
      },
      "items": {
        "type": "string",
        "enum": [
          "OBJ-014",
          "OBJ-018"
        ]
      }
    },
    "data_boundary": {
      "$ref": "#/$defs/DataBoundary"
    },
    "constraint_set": {
      "$ref": "#/$defs/ConstraintSet"
    }
  },
  "$defs": {
    "AssumptionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assumption_id",
        "statement",
        "status",
        "affected_refs",
        "provenance"
      ],
      "properties": {
        "assumption_id": {
          "$ref": "#/$defs/Id"
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "unresolved",
            "resolved",
            "rejected",
            "TBD"
          ]
        },
        "affected_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "ConstraintRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "constraint_id",
        "constraint_kind",
        "name",
        "state",
        "source_type",
        "target_refs",
        "design_knowledge_refs",
        "parameters",
        "diagnostics",
        "assumptions",
        "validation_status",
        "provenance",
        "professional_boundary"
      ],
      "properties": {
        "constraint_id": {
          "$ref": "#/$defs/Id"
        },
        "constraint_kind": {
          "$ref": "#/$defs/ConstraintKind"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "enum": [
            "proposed",
            "active",
            "inactive",
            "superseded",
            "blocked_by_missing_data",
            "TBD"
          ]
        },
        "source_type": {
          "$ref": "#/$defs/SourceType"
        },
        "target_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "design_knowledge_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Diagnostic"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AssumptionRecord"
          }
        },
        "validation_status": {
          "$ref": "#/$defs/ValidationStatus"
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        },
        "professional_boundary": {
          "$ref": "#/$defs/ProfessionalBoundary"
        }
      }
    },
    "ConstraintKind": {
      "type": "string",
      "enum": [
        "connectivity",
        "clearance",
        "no_go_volume",
        "support_zone",
        "route_conflict",
        "slope",
        "drain",
        "vent",
        "access",
        "equipment_interface",
        "missing_required_data",
        "TBD"
      ]
    },
    "ConstraintSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "constraint_set_id",
        "project_ref",
        "model_ref",
        "design_knowledge_refs",
        "constraints",
        "diagnostics",
        "provenance",
        "professional_boundary"
      ],
      "properties": {
        "constraint_set_id": {
          "$ref": "#/$defs/Id"
        },
        "project_ref": {
          "$ref": "#/$defs/Reference"
        },
        "model_ref": {
          "$ref": "#/$defs/Reference"
        },
        "design_knowledge_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "constraints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ConstraintRecord"
          }
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Diagnostic"
          }
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        },
        "professional_boundary": {
          "$ref": "#/$defs/ProfessionalBoundary"
        }
      }
    },
    "DataBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_examples_policy",
        "protected_source_policy",
        "private_data_policy",
        "unit_policy",
        "engineering_authority"
      ],
      "properties": {
        "public_examples_policy": {
          "const": "invented_or_cleared_data_only"
        },
        "protected_source_policy": {
          "const": "no_bundled_protected_owner_or_standards_data"
        },
        "private_data_policy": {
          "const": "user_controlled_private_paths"
        },
        "unit_policy": {
          "const": "unit_bearing_values_require_explicit_unit_metadata"
        },
        "engineering_authority": {
          "const": "human_review_required_outside_software"
        }
      }
    },
    "Diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "class",
        "severity",
        "source",
        "affected_object",
        "message",
        "remediation",
        "provenance"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "class": {
          "type": "string",
          "enum": [
            "CONSTRAINT_MISSING_DATA",
            "CONNECTIVITY_CONFLICT",
            "CLEARANCE_CONFLICT",
            "ROUTE_CONFLICT",
            "SUPPORT_ZONE_CONFLICT",
            "SLOPE_DRAIN_VENT_CONFLICT",
            "PROVENANCE_WARNING",
            "UNIT_WARNING",
            "IP_BOUNDARY_WARNING",
            "SCHEMA_VALIDATION",
            "TBD"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "blocking"
          ]
        },
        "source": {
          "$ref": "#/$defs/Reference"
        },
        "affected_object": {
          "$ref": "#/$defs/Reference"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "remediation": {
          "type": "string",
          "minLength": 1
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "Id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$"
    },
    "Parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameter_id",
        "name",
        "value",
        "value_kind",
        "provenance"
      ],
      "properties": {
        "parameter_id": {
          "$ref": "#/$defs/Id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "boolean"
            },
            {
              "$ref": "#/$defs/Quantity"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Reference"
              }
            }
          ]
        },
        "value_kind": {
          "type": "string",
          "enum": [
            "text",
            "flag",
            "quantity",
            "reference_list",
            "TBD"
          ]
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "PrivacyClassification": {
      "type": "string",
      "enum": [
        "public_metadata",
        "invented_public_example",
        "private_project_data",
        "owner_project_metadata_private",
        "protected_suspected",
        "redacted",
        "TBD"
      ]
    },
    "ProfessionalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_review_required",
        "software_makes_compliance_claim",
        "software_makes_certification_claim",
        "software_makes_sealing_claim",
        "software_makes_approval_claim",
        "software_makes_authentication_claim"
      ],
      "properties": {
        "human_review_required": {
          "const": true
        },
        "software_makes_compliance_claim": {
          "const": false
        },
        "software_makes_certification_claim": {
          "const": false
        },
        "software_makes_sealing_claim": {
          "const": false
        },
        "software_makes_approval_claim": {
          "const": false
        },
        "software_makes_authentication_claim": {
          "const": false
        }
      }
    },
    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_name",
        "source_location",
        "source_license",
        "contributor",
        "contributor_certification",
        "redistribution_status",
        "review_status",
        "privacy_classification"
      ],
      "properties": {
        "source_name": {
          "type": "string",
          "minLength": 1
        },
        "source_location": {
          "type": "string",
          "minLength": 1
        },
        "source_license": {
          "type": "string",
          "minLength": 1
        },
        "contributor": {
          "type": "string",
          "minLength": 1
        },
        "contributor_certification": {
          "type": "string",
          "minLength": 1
        },
        "redistribution_status": {
          "$ref": "#/$defs/RedistributionStatus"
        },
        "review_status": {
          "$ref": "#/$defs/ReviewStatus"
        },
        "privacy_classification": {
          "$ref": "#/$defs/PrivacyClassification"
        }
      }
    },
    "Quantity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "unit",
        "dimension",
        "provenance"
      ],
      "properties": {
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "dimension": {
          "type": "string",
          "enum": [
            "dimensionless",
            "length",
            "angle",
            "slope",
            "area",
            "volume",
            "temperature",
            "pressure",
            "force",
            "TBD"
          ]
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "RedistributionStatus": {
      "type": "string",
      "enum": [
        "public_permissive",
        "private_only",
        "unknown",
        "protected_suspected",
        "invented_non_engineering_example",
        "TBD"
      ]
    },
    "Reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_type",
        "ref"
      ],
      "properties": {
        "object_type": {
          "type": "string",
          "enum": [
            "Project",
            "Model",
            "DesignKnowledgeRecord",
            "Constraint",
            "Node",
            "Element",
            "Component",
            "Support",
            "LoadCase",
            "Diagnostic",
            "Assumption",
            "ExternalReference",
            "TBD"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        }
      }
    },
    "ReviewStatus": {
      "type": "string",
      "enum": [
        "pending",
        "accepted",
        "rejected",
        "quarantined",
        "TBD"
      ]
    },
    "SourceType": {
      "type": "string",
      "enum": [
        "user",
        "project",
        "import",
        "agent",
        "source_derived",
        "TBD"
      ]
    },
    "ValidationStatus": {
      "type": "string",
      "enum": [
        "unvalidated",
        "schema_validated",
        "constraint_validated",
        "conflict_detected",
        "missing_data",
        "blocked_by_missing_data",
        "TBD"
      ]
    }
  }
}

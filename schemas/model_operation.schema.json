{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpipestress.org/schemas/model_operation.schema.json",
  "title": "OpenPipeStress Structured Model Operation Schema",
  "description": "Strict JSON Schema 2020-12 contract for proposed model operations. Operations are the structured route for GUI and agent edit proposals and remain proposals until later validation, preview, and user review boundaries apply.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "deliverable_id",
    "package_id",
    "scope_item",
    "objectives",
    "operation_contract_status",
    "operation_set"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "deliverable_id": {
      "const": "DEL-16-01"
    },
    "package_id": {
      "const": "PKG-16"
    },
    "scope_item": {
      "const": "SOW-069"
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "contains": {
        "const": "OBJ-015"
      },
      "items": {
        "type": "string",
        "enum": [
          "OBJ-015"
        ]
      }
    },
    "operation_contract_status": {
      "$ref": "#/$defs/OperationContractStatus"
    },
    "operation_set": {
      "$ref": "#/$defs/OperationSet"
    }
  },
  "$defs": {
    "AssumptionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assumption_id",
        "statement",
        "status",
        "affected_refs",
        "provenance"
      ],
      "properties": {
        "assumption_id": {
          "$ref": "#/$defs/Id"
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "unresolved",
            "resolved",
            "rejected",
            "TBD"
          ]
        },
        "affected_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "Checksum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "canonicalization",
        "payload_ref",
        "payload_scope",
        "value"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "sha256",
            "sha512",
            "TBD"
          ]
        },
        "canonicalization": {
          "type": "string",
          "enum": [
            "JCS",
            "NONE",
            "TBD"
          ]
        },
        "payload_ref": {
          "$ref": "#/$defs/Reference"
        },
        "payload_scope": {
          "type": "string",
          "enum": [
            "operation_record",
            "model_state_record",
            "diff_preview",
            "external_reference",
            "TBD"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "class",
        "severity",
        "source",
        "affected_object",
        "message",
        "remediation",
        "provenance"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "class": {
          "type": "string",
          "enum": [
            "OPERATION_SCHEMA_BLOCKING",
            "OPERATION_PRECONDITION_BLOCKING",
            "CONSTRAINT_VALIDATION_BLOCKING",
            "DIFF_PREVIEW_REQUIRED",
            "UNIT_WARNING",
            "PROVENANCE_WARNING",
            "IP_BOUNDARY_WARNING",
            "HUMAN_REVIEW_REQUIRED",
            "TBD"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "blocking"
          ]
        },
        "source": {
          "$ref": "#/$defs/Reference"
        },
        "affected_object": {
          "$ref": "#/$defs/Reference"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "remediation": {
          "type": "string",
          "minLength": 1
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "DiffPreviewRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_ref",
        "preview_status",
        "checksum",
        "provenance"
      ],
      "properties": {
        "preview_ref": {
          "$ref": "#/$defs/Reference"
        },
        "preview_status": {
          "type": "string",
          "enum": [
            "not_generated",
            "generated",
            "blocked_by_validation",
            "TBD"
          ]
        },
        "checksum": {
          "$ref": "#/$defs/Checksum"
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "Id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$"
    },
    "ModelOperationRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_id",
        "operation_kind",
        "operation_status",
        "author_type",
        "target_refs",
        "preconditions",
        "changes",
        "validation",
        "diagnostics",
        "diff_preview_refs",
        "assumptions",
        "provenance",
        "professional_boundary"
      ],
      "properties": {
        "operation_id": {
          "$ref": "#/$defs/Id"
        },
        "operation_kind": {
          "$ref": "#/$defs/OperationKind"
        },
        "operation_status": {
          "$ref": "#/$defs/OperationStatus"
        },
        "author_type": {
          "$ref": "#/$defs/OperationAuthorType"
        },
        "target_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "preconditions": {
          "$ref": "#/$defs/OperationPrecondition"
        },
        "changes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/OperationChange"
          }
        },
        "validation": {
          "$ref": "#/$defs/OperationValidation"
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Diagnostic"
          }
        },
        "diff_preview_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DiffPreviewRef"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AssumptionRecord"
          }
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        },
        "professional_boundary": {
          "$ref": "#/$defs/ProfessionalBoundary"
        }
      }
    },
    "OperationAuthorType": {
      "type": "string",
      "enum": [
        "user",
        "agent",
        "import_adapter",
        "project_template",
        "TBD"
      ]
    },
    "OperationChange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "change_id",
        "change_kind",
        "target_object_type",
        "value_payload",
        "unit_requirements",
        "provenance"
      ],
      "properties": {
        "change_id": {
          "$ref": "#/$defs/Id"
        },
        "change_kind": {
          "type": "string",
          "enum": [
            "add_object",
            "remove_object",
            "set_field",
            "move_geometry",
            "reconnect",
            "update_constraint",
            "update_load",
            "update_support",
            "attach_design_knowledge",
            "TBD"
          ]
        },
        "target_object_type": {
          "type": "string",
          "enum": [
            "Node",
            "Element",
            "Component",
            "Support",
            "Load",
            "Constraint",
            "DesignKnowledgeRecord",
            "ModelMetadata",
            "TBD"
          ]
        },
        "value_payload": {
          "$ref": "#/$defs/OperationValuePayload"
        },
        "unit_requirements": {
          "$ref": "#/$defs/UnitRequirements"
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "OperationContractStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_contract",
        "mutation_route",
        "direct_model_mutation_allowed",
        "user_acceptance_boundary",
        "diff_preview_binding",
        "audit_trail_binding"
      ],
      "properties": {
        "record_contract": {
          "const": "schema_first_model_operation_records"
        },
        "mutation_route": {
          "const": "structured_operations_only"
        },
        "direct_model_mutation_allowed": {
          "const": false
        },
        "user_acceptance_boundary": {
          "const": "downstream_user_acceptance_required"
        },
        "diff_preview_binding": {
          "const": "downstream_DEL-16-02"
        },
        "audit_trail_binding": {
          "const": "downstream_DEL-16-03"
        }
      }
    },
    "OperationKind": {
      "type": "string",
      "enum": [
        "add",
        "move",
        "modify",
        "delete",
        "reconnect",
        "constraint",
        "load",
        "support",
        "design_knowledge",
        "TBD"
      ]
    },
    "OperationPrecondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_model_state_ref",
        "required_current_hashes",
        "required_refs",
        "assumptions"
      ],
      "properties": {
        "base_model_state_ref": {
          "$ref": "#/$defs/Reference"
        },
        "required_current_hashes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Checksum"
          }
        },
        "required_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AssumptionRecord"
          }
        }
      }
    },
    "OperationSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_set_id",
        "project_ref",
        "model_ref",
        "operations",
        "diagnostics",
        "provenance",
        "professional_boundary"
      ],
      "properties": {
        "operation_set_id": {
          "$ref": "#/$defs/Id"
        },
        "project_ref": {
          "$ref": "#/$defs/Reference"
        },
        "model_ref": {
          "$ref": "#/$defs/Reference"
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ModelOperationRecord"
          }
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Diagnostic"
          }
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        },
        "professional_boundary": {
          "$ref": "#/$defs/ProfessionalBoundary"
        }
      }
    },
    "OperationStatus": {
      "type": "string",
      "enum": [
        "proposed",
        "schema_validated",
        "blocked_by_diagnostics",
        "ready_for_user_review",
        "rejected",
        "TBD"
      ]
    },
    "OperationValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_validation",
        "constraint_validation",
        "unit_validation",
        "diff_preview_status",
        "application_status"
      ],
      "properties": {
        "schema_validation": {
          "$ref": "#/$defs/ValidationState"
        },
        "constraint_validation": {
          "$ref": "#/$defs/ValidationState"
        },
        "unit_validation": {
          "$ref": "#/$defs/ValidationState"
        },
        "diff_preview_status": {
          "type": "string",
          "enum": [
            "not_generated",
            "generated",
            "blocked_by_validation",
            "TBD"
          ]
        },
        "application_status": {
          "type": "string",
          "enum": [
            "not_applied",
            "held_for_user_review",
            "downstream_application_required",
            "TBD"
          ]
        }
      }
    },
    "OperationValuePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value_kind",
        "scalar_values",
        "quantity_values",
        "reference_values",
        "notes"
      ],
      "properties": {
        "value_kind": {
          "type": "string",
          "enum": [
            "text",
            "quantity",
            "reference_list",
            "structured_patch",
            "TBD"
          ]
        },
        "scalar_values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "quantity_values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Quantity"
          }
        },
        "reference_values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "PrivacyClassification": {
      "type": "string",
      "enum": [
        "public_metadata",
        "invented_public_example",
        "private_project_data",
        "owner_project_metadata_private",
        "protected_suspected",
        "redacted",
        "TBD"
      ]
    },
    "ProfessionalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_review_required",
        "software_makes_compliance_claim",
        "software_makes_certification_claim",
        "software_makes_sealing_claim",
        "software_makes_approval_claim",
        "software_makes_authentication_claim"
      ],
      "properties": {
        "human_review_required": {
          "const": true
        },
        "software_makes_compliance_claim": {
          "const": false
        },
        "software_makes_certification_claim": {
          "const": false
        },
        "software_makes_sealing_claim": {
          "const": false
        },
        "software_makes_approval_claim": {
          "const": false
        },
        "software_makes_authentication_claim": {
          "const": false
        }
      }
    },
    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_name",
        "source_location",
        "source_license",
        "contributor",
        "contributor_certification",
        "redistribution_status",
        "review_status",
        "privacy_classification"
      ],
      "properties": {
        "source_name": {
          "type": "string",
          "minLength": 1
        },
        "source_location": {
          "type": "string",
          "minLength": 1
        },
        "source_license": {
          "type": "string",
          "minLength": 1
        },
        "contributor": {
          "type": "string",
          "minLength": 1
        },
        "contributor_certification": {
          "type": "string",
          "minLength": 1
        },
        "redistribution_status": {
          "$ref": "#/$defs/RedistributionStatus"
        },
        "review_status": {
          "$ref": "#/$defs/ReviewStatus"
        },
        "privacy_classification": {
          "$ref": "#/$defs/PrivacyClassification"
        }
      }
    },
    "Quantity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "unit",
        "dimension",
        "provenance"
      ],
      "properties": {
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "dimension": {
          "type": "string",
          "enum": [
            "dimensionless",
            "length",
            "angle",
            "slope",
            "force",
            "moment",
            "pressure",
            "temperature",
            "TBD"
          ]
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        }
      }
    },
    "RedistributionStatus": {
      "type": "string",
      "enum": [
        "public_permissive",
        "private_only",
        "unknown",
        "protected_suspected",
        "invented_non_engineering_example",
        "TBD"
      ]
    },
    "Reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_type",
        "ref"
      ],
      "properties": {
        "object_type": {
          "type": "string",
          "enum": [
            "Project",
            "Model",
            "ModelState",
            "ModelOperation",
            "Node",
            "Element",
            "Component",
            "Support",
            "Load",
            "Constraint",
            "DesignKnowledgeRecord",
            "Diagnostic",
            "DiffPreview",
            "ExternalReference",
            "TBD"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        }
      }
    },
    "ReviewStatus": {
      "type": "string",
      "enum": [
        "pending",
        "accepted",
        "rejected",
        "quarantined",
        "TBD"
      ]
    },
    "UnitRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit_metadata_required",
        "dimension_check_required",
        "missing_unit_behavior"
      ],
      "properties": {
        "unit_metadata_required": {
          "const": true
        },
        "dimension_check_required": {
          "const": true
        },
        "missing_unit_behavior": {
          "const": "emit_diagnostic"
        }
      }
    },
    "ValidationState": {
      "type": "string",
      "enum": [
        "not_run",
        "passed",
        "warning",
        "blocking",
        "TBD"
      ]
    }
  }
}
